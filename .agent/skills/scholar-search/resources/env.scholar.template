# === Scholar Search Skill 配置 ===
# 将此文件复制为项目根目录 .env.scholar 并填入真实 Key
# 已被 .gitignore 忽略，不会提交到版本库

# SerpApi（Google Scholar 封装，可选）
# 注册地址: https://serpapi.com/ — 免费层每月 100 次
# 若未配置，搜索将自动降级到 Semantic Scholar 免费 API
SERPAPI_API_KEY=

# Semantic Scholar API Key（可选）
# 注册地址: https://www.semanticscholar.org/product/api
# 无 Key 也可用（100次/5分钟），有 Key 速率限制更高（1次/秒）
SEMANTIC_SCHOLAR_API_KEY=

# Elicit API（可选，商业 API）
# 注册地址: https://elicit.com/
ELICIT_API_KEY=

# 默认存储路径（相对于项目根目录）
SCHOLAR_PAPERS_DIR=data/papers
