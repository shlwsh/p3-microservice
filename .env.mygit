# AI Git 提交工具配置

# 您的 API 密钥（必填）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-你的密钥

# API 基础 URL（必填，通常不需要修改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可用模型列表:
# - deepseek-v3: DeepSeek V3 模型（推荐，性价比最高）
# - qwen-vl-plus: 通义千问视觉增强版
# - deepseek-r1: DeepSeek R1 推理模型
# - deepseek-v3.2-exp: DeepSeek V3.2 实验版
DASHSCOPE_MODEL=deepseek-v3

# 本地 HTTP 代理（WSL2 推荐 127.0.0.1:7897，按你的 Clash/V2Ray 端口修改）
MYGIT_HTTP_PROXY=http://127.0.0.1:7897

# GitHub 推送 PAT：写入项目根目录 .env.local（已 gitignore，勿写入本文件或提交）
# 创建: GitHub → Settings → Developer settings → Personal access tokens
# 示例 .env.local 内容: GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# 性能相关（可选）
# MYGIT_NO_AI=1              # 始终用规则生成，不调用 AI（最快）
# MYGIT_FAST_RULES=1         # 同 MYGIT_NO_AI
# MYGIT_AI_TIMEOUT_MS=15000  # AI 超时毫秒数，超时后自动规则回退
# MYGIT_FORCE_AI=1           # 暂存区含 PDF/ZIP 时仍调用 AI（默认跳过以加速）
# MYGIT_AI_PROBE_TIMEOUT_MS=8000   # 提交前 AI 连通性探测超时
# MYGIT_SKIP_AI_PROBE=1      # 跳过连通性探测（不推荐）
